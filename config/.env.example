# media-manager environment configuration
# Copy this file to config/.env and fill in your values.
# Run install.sh to generate AUTH_SECRET_KEY, PLEX_CLIENT_ID, and a starter .env automatically.

# ── Server ────────────────────────────────────────────────────────────────────

# Port the web UI listens on (host side). Default: 10400.
PORT=10400

# ── Auth (required) ───────────────────────────────────────────────────────────

# Secret used to sign session cookies. Generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
AUTH_SECRET_KEY=

# Unique client identifier sent to plex.tv. Generate with:
#   python3 -c "import uuid; print(uuid.uuid4())"
PLEX_CLIENT_ID=

# ── Setup wizard ──────────────────────────────────────────────────────────────

# Set to true once the setup wizard has been completed.
# The wizard sets this automatically via /api/setup/save.
# While false, all requests are redirected to /setup.
SETUP_COMPLETE=false

# ── Sonarr (TV library) ───────────────────────────────────────────────────────
# At least one of SONARR_URL or RADARR_URL is required.
# Multiple instances: use comma-separated values, keys matched by position.
#   e.g. SONARR_URL=http://host1:8989,http://host2:8989
#        SONARR_API_KEY=key1,key2
SONARR_URL=
SONARR_API_KEY=

# ── Radarr (movie library) ────────────────────────────────────────────────────
# Multiple instances: same comma-separated pattern as Sonarr.
RADARR_URL=
RADARR_API_KEY=

# ── Overseerr / Jellyseerr (requests & watchlists) ───────────────────────────
SEERR_URL=
SEERR_API_KEY=

# ── Plex (watch history, user profiles) ──────────────────────────────────────
PLEX_URL=
PLEX_TOKEN=

# Comma-separated Plex library section IDs for TV and movies.
# Find section IDs via: GET <PLEX_URL>/library/sections?X-Plex-Token=<token>
# Defaults: TV=1, Movies=2
PLEX_TV_SECTIONS=1
PLEX_MOVIE_SECTIONS=2

# ── Tautulli (enhanced watch statistics) ─────────────────────────────────────
TAUTULLI_URL=
TAUTULLI_API_KEY=

# ── TMDB (posters, ratings, descriptions) ────────────────────────────────────
# Get a free API key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# ── Storage forecasting ───────────────────────────────────────────────────────
# Total usable storage capacity in gigabytes. Used for forecasting charts.
# Leave blank to disable storage forecasting.
STORAGE_CAPACITY_GB=
